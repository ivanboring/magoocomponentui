---
import "../styles/app.css";
import { rebase } from "../lib/data.js";
const { title = "Magoo Component UI" } = Astro.props;
const BASE = import.meta.env.BASE_URL;
// The app home is the deploy base (e.g. "/repo/" on GitHub Pages), never the server root "/".
const home = BASE;
const path = Astro.url.pathname.replace(/\/$/, "");
const base = BASE.replace(/\/$/, "");
// A nav item is active when the current path is (under) its target.
const isActive = (href) => {
  const h = href.replace(/\/$/, "");
  if (h === base) return path === base; // Components == exact home
  return path === h || path.startsWith(h + "/");
};
const nav = [
  { label: "Components", href: home },
  { label: "Examples", href: rebase("/examples", BASE) },
  { label: "About", href: rebase("/about", BASE) },
];
---

<!doctype html>
<html lang="en" class="bg-slate-50 text-slate-900">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={rebase("/favicon.ico", BASE)} sizes="any" />
    <link rel="icon" type="image/png" href={rebase("/logo.png", BASE)} />
    <link rel="apple-touch-icon" href={rebase("/logo.png", BASE)} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased [font-family:ui-sans-serif,system-ui,sans-serif]">
    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center gap-4 px-5 py-3">
        <a href={home} class="flex items-center gap-2 font-semibold tracking-tight">
          <img src={rebase("/logo.png", BASE)} alt="Magoo Component UI logo" width="28" height="28" class="h-7 w-7" />
          Magoo Component UI
        </a>
        <span class="hidden text-sm text-slate-400 lg:inline">CSS-less skeletons · 4 themes</span>
        <!-- Inline nav on sm+; collapses to a hamburger on mobile. -->
        <nav class="ml-auto hidden items-center gap-1 text-sm sm:flex">
          {nav.map((n) => (
            <a
              href={n.href}
              aria-current={isActive(n.href) ? "page" : undefined}
              class="rounded-md px-3 py-1.5 text-slate-600 hover:bg-slate-100 hover:text-slate-900 aria-[current=page]:bg-slate-900 aria-[current=page]:text-white"
            >{n.label}</a>
          ))}
        </nav>
        <button
          id="nav-toggle"
          type="button"
          class="ml-auto rounded-md p-2 text-slate-600 hover:bg-slate-100 hover:text-slate-900 sm:hidden"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <svg class="nav-open size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
          <svg class="nav-close hidden size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
        </button>
      </div>
      <!-- Mobile dropdown menu (hidden on sm+; toggled open on mobile). -->
      <nav id="mobile-nav" class="hidden border-t border-slate-200 bg-white px-5 py-2 shadow-sm sm:hidden" aria-label="Main">
        <div class="mx-auto flex max-w-6xl flex-col gap-1 text-sm">
          {nav.map((n) => (
            <a
              href={n.href}
              aria-current={isActive(n.href) ? "page" : undefined}
              class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100 hover:text-slate-900 aria-[current=page]:bg-slate-900 aria-[current=page]:text-white"
            >{n.label}</a>
          ))}
        </div>
      </nav>
    </header>
    <script is:inline>
      (function () {
        var btn = document.getElementById("nav-toggle");
        var menu = document.getElementById("mobile-nav");
        if (!btn || !menu) return;
        var open = btn.querySelector(".nav-open");
        var close = btn.querySelector(".nav-close");
        function setOpen(v) {
          menu.classList.toggle("hidden", !v);
          btn.setAttribute("aria-expanded", String(v));
          if (open) open.classList.toggle("hidden", v);
          if (close) close.classList.toggle("hidden", !v);
        }
        btn.addEventListener("click", function () { setOpen(menu.classList.contains("hidden")); });
        // Close after picking a destination or pressing Escape.
        menu.addEventListener("click", function (e) { if (e.target.closest("a")) setOpen(false); });
        document.addEventListener("keydown", function (e) { if (e.key === "Escape") setOpen(false); });
      })();
    </script>
    <div class="mx-auto max-w-6xl px-5 py-8">
      <slot />
    </div>
  </body>
</html>
