---
import Layout from "../../layouts/Layout.astro";
import { loadCatalog, loadExamples, THEMES, orderedShots } from "../../lib/data.js";
import { renderToHtml } from "@magoo/generator";

export function getStaticPaths() {
  const catalog = loadCatalog();
  return catalog.components.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { ast, names } = loadExamples(entry.id);
const examples = names.map((ex) => ({ ...ex, html: renderToHtml(ast, ex.args) }));
// Every example's behaviors, de-duplicated, loaded once for the whole page.
const behaviors = [...new Set(examples.flatMap((ex) => ex.behaviors))];
const cat = entry.categorization || {};
// Card-like components can be previewed inside a responsive grid (×2/×3/×4).
const usageTypes = cat.usage_type || [];
const isGridEligible = usageTypes.includes("card") || usageTypes.includes("grid") || cat.category === "Cards";

const catalog = loadCatalog();
const byId = new Map(catalog.components.map((c) => [c.id, c]));
const rel = entry.relationships || { parents: [], children: [], related: [] };
const relGroups = [
  { label: "Part of", ids: rel.parents || [] },
  { label: "Contains", ids: rel.children || [] },
  { label: "Related", ids: rel.related || [] },
].filter((g) => g.ids.length);
---

<Layout title={`${entry.display_name} — Magoo Component UI`}>
  <a href="/" class="text-sm text-slate-500 hover:text-slate-900">&larr; Catalog</a>

  <div class="mt-3 flex flex-wrap items-center gap-3">
    <h1 class="text-2xl font-semibold tracking-tight">{entry.display_name}</h1>
    <code class="rounded bg-slate-100 px-2 py-0.5 font-mono text-xs text-slate-500">{entry.name}</code>
    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-500">{cat.atomic_type}</span>
    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-500">{entry.lifecycle}</span>
  </div>
  <p class="mt-2 max-w-2xl text-slate-600">{entry.short_description}</p>

  <!-- Live stage with theme switch + optional grid-layout dropdown -->
  <div class="mt-6 flex flex-wrap items-center gap-2">
    {THEMES.map((t, i) => (
      <button
        class="theme-btn rounded-md border border-slate-300 px-3 py-1 text-sm hover:bg-slate-100 aria-[current=true]:border-slate-900 aria-[current=true]:bg-slate-900 aria-[current=true]:text-white"
        data-theme-id={t.id}
        aria-current={i === 0 ? "true" : "false"}
      >{t.label}</button>
    ))}
    {isGridEligible && (
      <select id="layout" title="Preview layout" class="ml-auto rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm outline-none focus:border-slate-500">
        <option value="1">Single</option>
        <option value="2">Grid × 2</option>
        <option value="3">Grid × 3</option>
        <option value="4">Grid × 4</option>
      </select>
    )}
  </div>
  <div class="mt-3 space-y-4">
    {examples.map((ex) => (
      <div>
        {examples.length > 1 && (
          <div class="mb-1 text-xs font-medium uppercase tracking-wide text-slate-400">{ex.name}</div>
        )}
        <div data-theme="simple" class="stage rounded-xl border border-slate-200 p-8">
          <div class="stage-content" set:html={ex.html} />
        </div>
      </div>
    ))}
  </div>

  <!-- Screenshots grid, when present -->
  {Object.keys(entry.screenshots || {}).length > 0 && (
    <section class="mt-8">
      <h2 class="mb-3 text-lg font-semibold">Screenshots <span class="text-sm font-normal text-slate-400">— click to enlarge</span></h2>
      <div class="space-y-4">
        {THEMES.filter((t) => entry.screenshots[t.id]).map((t) => (
          <div>
            <div class="mb-1 text-xs uppercase tracking-wide text-slate-400">{t.label}</div>
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
              {orderedShots(entry.screenshots, t.id).map(({ bp, src }) => (
                <figure>
                  <button type="button" class="shot block w-full" data-full={src} data-label={`${t.label} · ${bp}`}>
                    <img src={src} alt={`${t.label} ${bp}`} class="w-full cursor-zoom-in rounded border border-slate-200 transition hover:border-slate-400" />
                  </button>
                  <figcaption class="mt-1 text-[11px] text-slate-400">{bp}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Full-preview lightbox (← / → to navigate) -->
  <div id="lightbox" hidden class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-6">
    <button id="lightbox-close" class="absolute right-5 top-4 text-2xl text-white/80 hover:text-white" aria-label="Close">&times;</button>
    <button id="lightbox-prev" class="absolute left-3 top-1/2 -translate-y-1/2 px-3 text-4xl text-white/70 hover:text-white" aria-label="Previous">&lsaquo;</button>
    <button id="lightbox-next" class="absolute right-3 top-1/2 -translate-y-1/2 px-3 text-4xl text-white/70 hover:text-white" aria-label="Next">&rsaquo;</button>
    <figure class="max-w-full">
      <img id="lightbox-img" src="" alt="" class="mx-auto max-h-[82vh] max-w-full rounded shadow-2xl" />
      <figcaption id="lightbox-cap" class="mt-3 text-center text-sm text-white/80"></figcaption>
    </figure>
  </div>

  <div class="mt-8 grid gap-8 lg:grid-cols-2">
    {entry.props.length > 0 && (
      <section>
        <h2 class="mb-2 text-lg font-semibold">Props</h2>
        <table class="w-full text-sm">
          <thead><tr class="border-b text-left text-slate-400"><th class="py-1">Name</th><th>Type</th><th>Req</th></tr></thead>
          <tbody>
            {entry.props.map((p) => (
              <tr class="border-b border-slate-100 align-top">
                <td class="py-1 font-mono text-xs">{p.name}</td>
                <td class="text-slate-500">{p.type}{p.type === "enum" ? ` (${p.values.join(" | ")})` : ""}</td>
                <td>{p.required ? "✓" : ""}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}
    {entry.slots.length > 0 && (
      <section>
        <h2 class="mb-2 text-lg font-semibold">Slots</h2>
        <ul class="text-sm text-slate-600">
          {entry.slots.map((s) => (<li class="border-b border-slate-100 py-1"><span class="font-mono text-xs">{s.name}</span> — {s.usage || s.description}</li>))}
        </ul>
      </section>
    )}
  </div>

  {relGroups.length > 0 && (
    <section class="mt-8">
      <h2 class="mb-2 text-lg font-semibold">Related components</h2>
      <div class="flex flex-col gap-2 text-sm">
        {relGroups.map((g) => (
          <div class="flex flex-wrap items-center gap-2">
            <span class="w-20 shrink-0 text-slate-400">{g.label}</span>
            {g.ids.map((id) => {
              const t = byId.get(id);
              return t ? (
                <a href={`/c/${id}`} class="rounded-full border border-slate-200 px-3 py-1 hover:border-slate-400">
                  {t.display_name} <span class="text-slate-400">· {t.categorization.atomic_type}</span>
                </a>
              ) : (
                <span class="rounded-full border border-dashed border-slate-200 px-3 py-1 text-slate-400">{id}</span>
              );
            })}
          </div>
        ))}
      </div>
    </section>
  )}

  {entry.use_cases.length > 0 && (
    <section class="mt-8">
      <h2 class="mb-2 text-lg font-semibold">Use cases</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600">{entry.use_cases.map((u) => (<li>{u}</li>))}</ul>
    </section>
  )}

  <section class="mt-8 flex flex-wrap gap-2 text-xs">
    {cat.usage_type?.map((u) => (<span class="rounded bg-slate-100 px-2 py-1 text-slate-600">{u}</span>))}
    {cat.wcag?.level && <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700">WCAG {cat.wcag.level}</span>}
    {typeof cat.seo_score === "number" && <span class="rounded bg-slate-100 px-2 py-1 text-slate-600">SEO {cat.seo_score}</span>}
    {cat.text_direction && <span class="rounded bg-slate-100 px-2 py-1 text-slate-600">dir: {cat.text_direction}</span>}
    <span class="rounded bg-slate-100 px-2 py-1 text-slate-600">{cat.maturity}</span>
  </section>

  <script is:inline define:vars={{ behaviors }}>
    const THEME_KEY = "magoo-theme";
    function applyTheme(themeId) {
      document.querySelectorAll(".stage").forEach((s) => { s.dataset.theme = themeId; });
      document.querySelectorAll(".theme-btn").forEach((b) => b.setAttribute("aria-current", String(b.dataset.themeId === themeId)));
    }
    document.querySelectorAll(".theme-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        applyTheme(btn.dataset.themeId);
        try { localStorage.setItem(THEME_KEY, btn.dataset.themeId); } catch {}
      });
    });
    // Restore the last-picked theme (persists across pages).
    try {
      const saved = localStorage.getItem(THEME_KEY);
      if (saved && document.querySelector(`.theme-btn[data-theme-id="${saved}"]`)) applyTheme(saved);
    } catch {}

    // Grid-layout preview: duplicate each card into an N-column responsive grid.
    const layout = document.getElementById("layout");
    if (layout) {
      const stages = [...document.querySelectorAll(".stage-content")].map((el) => ({ el, single: el.innerHTML }));
      const LAYOUT_KEY = "magoo-layout";
      function applyLayout(cols) {
        for (const { el, single } of stages) {
          if (cols === "1") { el.innerHTML = single; continue; }
          const n = Number(cols) * 2; // two rows so the grid reads clearly
          el.innerHTML = `<div class="grid gap-4 grid-cols-${cols}">${Array.from({ length: n }, () => single).join("")}</div>`;
        }
      }
      layout.addEventListener("change", () => {
        applyLayout(layout.value);
        try { localStorage.setItem(LAYOUT_KEY, layout.value); } catch {}
      });
      try {
        const savedLayout = localStorage.getItem(LAYOUT_KEY);
        if (savedLayout && ["1", "2", "3", "4"].includes(savedLayout)) { layout.value = savedLayout; applyLayout(savedLayout); }
      } catch {}
    }

    // The viewed component's own behavior, plus any slotted children's, so
    // composed demos (e.g. ticket-card steppers inside ticket-selector) are live.
    for (const js of behaviors || []) {
      const s = document.createElement("script");
      s.textContent = js;
      document.body.appendChild(s);
    }

    // Screenshot lightbox with prev/next
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img");
    const lightboxCap = document.getElementById("lightbox-cap");
    const shotButtons = [...document.querySelectorAll(".shot")];
    const shots = shotButtons.map((b) => ({ src: b.dataset.full, label: b.dataset.label }));
    let idx = 0;

    function show(i) {
      idx = (i + shots.length) % shots.length;
      lightboxImg.src = shots[idx].src;
      lightboxImg.alt = shots[idx].label;
      lightboxCap.textContent = shots[idx].label;
    }
    function openLightbox(i) {
      show(i);
      lightbox.hidden = false;
      document.body.style.overflow = "hidden";
    }
    function closeLightbox() {
      lightbox.hidden = true;
      lightboxImg.src = "";
      document.body.style.overflow = "";
    }
    shotButtons.forEach((btn, i) => btn.addEventListener("click", () => openLightbox(i)));
    document.getElementById("lightbox-close").addEventListener("click", closeLightbox);
    document.getElementById("lightbox-prev").addEventListener("click", (e) => { e.stopPropagation(); show(idx - 1); });
    document.getElementById("lightbox-next").addEventListener("click", (e) => { e.stopPropagation(); show(idx + 1); });
    lightbox.addEventListener("click", (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener("keydown", (e) => {
      if (lightbox.hidden) return;
      if (e.key === "Escape") closeLightbox();
      else if (e.key === "ArrowLeft") show(idx - 1);
      else if (e.key === "ArrowRight") show(idx + 1);
    });
  </script>
</Layout>
