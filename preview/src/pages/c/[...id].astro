---
import Layout from "../../layouts/Layout.astro";
import { loadCatalog, loadExamples, loadMetadataYaml, renderInContainer, isContainer, isCardLeaf, rebase, rebaseHtml, THEMES } from "../../lib/data.js";
import { renderToHtml } from "@magoo/generator";

const BASE = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const catalog = loadCatalog();
  return catalog.components.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const metaYaml = loadMetadataYaml(entry.id);
const { ast, names } = loadExamples(entry.id);
const examplesRaw = names.map((ex) => ({ ...ex, html: rebaseHtml(renderToHtml(ast, ex.args), BASE) }));
const cat = entry.categorization || {};

const catalog = loadCatalog();
const byId = new Map(catalog.components.map((c) => [c.id, c]));

// Leaf cards can be previewed inside real container components — never containers themselves
// (no grid-in-a-grid). Generic containers accept any card; specific ones are matched via
// the relationships graph (e.g. a card whose parent container lists it as a child).
const gridEligible = isCardLeaf(entry);
const GENERIC_CONTAINERS = [
  { id: "cards/card-grid", label: "Card grid × 1", args: { mobile_cols: 1, tablet_cols: 1, desktop_cols: 1 }, copies: 2 },
  { id: "cards/card-grid", label: "Card grid × 2", args: { mobile_cols: 1, tablet_cols: 2, desktop_cols: 2 }, copies: 4 },
  { id: "cards/card-grid", label: "Card grid × 3", args: { mobile_cols: 1, tablet_cols: 2, desktop_cols: 3 }, copies: 6 },
  { id: "cards/card-grid", label: "Card grid × 4", args: { mobile_cols: 2, tablet_cols: 3, desktop_cols: 4 }, copies: 8 },
  { id: "layout/card-slider", label: "Card slider", args: {}, copies: 6 },
  { id: "layout/masonry-grid", label: "Masonry grid", args: { columns: 3 }, copies: 6 },
  { id: "layout/card-rail", label: "Card rail", args: {}, copies: 6 },
];
// Specific containers: a built component that lists this card as a child AND exposes an
// items/plans slot (so the card HTML can be slotted in). Array-prop grids can't take slots.
const hasItemsSlot = (c) => (c.slots || []).some((s) => s.name === "items" || s.name === "plans");
const genericIds = new Set(GENERIC_CONTAINERS.map((g) => g.id));
const specificContainers = gridEligible
  ? catalog.components
      .filter((c) => hasItemsSlot(c) && !genericIds.has(c.id) && (c.relationships?.children || []).includes(entry.id))
      .map((c) => ({ id: c.id, label: c.display_name, args: {}, copies: 3 }))
  : [];
const containerDefs = gridEligible ? [...GENERIC_CONTAINERS, ...specificContainers] : [];

// For each example, precompute the "single" HTML plus one variant per container.
const containerBehaviors = new Set();
const examples = examplesRaw.map((ex) => {
  const variants = { single: ex.html };
  for (const def of containerDefs) {
    const inner = ex.html.repeat(def.copies);
    const rendered = renderInContainer(def.id, inner, def.args);
    if (rendered) {
      variants[def.label] = rebaseHtml(rendered.html, BASE);
      if (rendered.behavior) containerBehaviors.add(rendered.behavior);
    }
  }
  return { ...ex, variants };
});
const layoutOptions = gridEligible ? ["single", ...containerDefs.map((d) => d.label)] : [];
// Every example's behaviors + container behaviors, de-duplicated, loaded once for the page.
const behaviors = [...new Set([...examples.flatMap((ex) => ex.behaviors), ...containerBehaviors])];

const rel = entry.relationships || { parents: [], children: [], related: [] };
const relGroups = [
  { label: "Part of", ids: rel.parents || [] },
  { label: "Contains", ids: rel.children || [] },
  { label: "Related", ids: rel.related || [] },
].filter((g) => g.ids.length);
---

<Layout title={`${entry.display_name} — Magoo Component UI`}>
  <a href={rebase("/", BASE)} class="text-sm text-slate-500 hover:text-slate-900">&larr; Catalog</a>

  <div class="mt-3 flex flex-wrap items-center gap-3">
    <h1 class="text-2xl font-semibold tracking-tight">{entry.display_name}</h1>
    <code class="rounded bg-slate-100 px-2 py-0.5 font-mono text-xs text-slate-500">{entry.name}</code>
    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-500">{cat.atomic_type}</span>
    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-500">{entry.lifecycle}</span>
    {metaYaml && (
      <button id="meta-btn" type="button" class="ml-auto rounded-md border border-slate-300 px-3 py-1 text-sm hover:bg-slate-100">View metadata</button>
    )}
  </div>
  <p class="mt-2 max-w-2xl text-slate-600">{entry.short_description}</p>
  {entry.secondary_categories && entry.secondary_categories.length > 0 && (
    <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-slate-500">
      <span>Also in:</span>
      {entry.secondary_categories.map((s) => (
        <span class="rounded-full bg-slate-100 px-2 py-0.5 text-slate-500">{s}</span>
      ))}
    </div>
  )}

  <!-- Live stage: theme switch, full-width toggle, and (for leaf cards) a container dropdown -->
  <div class="mt-6 flex flex-wrap items-center gap-2">
    {THEMES.map((t, i) => (
      <button
        class="theme-btn rounded-md border border-slate-300 px-3 py-1 text-sm hover:bg-slate-100 aria-[current=true]:border-slate-900 aria-[current=true]:bg-slate-900 aria-[current=true]:text-white"
        data-theme-id={t.id}
        aria-current={i === 0 ? "true" : "false"}
      >{t.label}</button>
    ))}
    <div class="ml-auto flex items-center gap-2">
      {gridEligible && (
        <select id="layout" title="Show inside a container" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm outline-none focus:border-slate-500">
          {layoutOptions.map((opt) => (
            <option value={opt}>{opt === "single" ? "Single" : opt}</option>
          ))}
        </select>
      )}
      <select id="stage-width" title="Preview width / breakpoint" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm outline-none focus:border-slate-500">
        <option value="">Auto width</option>
        <option value="full">Full width</option>
        <option value="1440">Desktop · 1440</option>
        <option value="1024">Small · 1024</option>
        <option value="768">Tablet · 768</option>
        <option value="375">Mobile · 375</option>
      </select>
    </div>
  </div>
  <div id="stages" class="mt-3 space-y-4">
    {examples.map((ex) => (
      <div>
        {examples.length > 1 && (
          <div class="mb-1 text-xs font-medium uppercase tracking-wide text-slate-400">{ex.name}</div>
        )}
        <div data-theme="simple" class="stage rounded-xl border border-slate-200 p-8">
          <div class="stage-content" data-variants={gridEligible ? JSON.stringify(ex.variants) : undefined} set:html={ex.html} />
        </div>
      </div>
    ))}
  </div>

  <!-- Full metadata.yml modal (opened from "View metadata") -->
  <div id="meta-modal" hidden class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-6">
    <div class="flex max-h-[85vh] w-full max-w-2xl flex-col overflow-hidden rounded-xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
        <h2 class="text-sm font-semibold">metadata.yml <code class="ml-1 font-mono text-xs font-normal text-slate-400">{entry.id}</code></h2>
        <button id="meta-close" type="button" class="text-2xl leading-none text-slate-500 hover:text-slate-900" aria-label="Close">&times;</button>
      </div>
      <pre class="overflow-auto bg-slate-50 p-4 text-xs leading-relaxed text-slate-800"><code>{metaYaml}</code></pre>
    </div>
  </div>

  <div class="mt-8 grid gap-8 lg:grid-cols-2">
    {entry.props.length > 0 && (
      <section>
        <h2 class="mb-2 text-lg font-semibold">Props</h2>
        <table class="w-full text-sm">
          <thead><tr class="border-b text-left text-slate-400"><th class="py-1">Name</th><th>Type</th><th>Req</th></tr></thead>
          <tbody>
            {entry.props.map((p) => (
              <tr class="border-b border-slate-100 align-top">
                <td class="py-1 font-mono text-xs">{p.name}</td>
                <td class="text-slate-500">{p.type}{p.type === "enum" ? ` (${p.values.join(" | ")})` : ""}</td>
                <td>{p.required ? "✓" : ""}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}
    {entry.slots.length > 0 && (
      <section>
        <h2 class="mb-2 text-lg font-semibold">Slots</h2>
        <ul class="text-sm text-slate-600">
          {entry.slots.map((s) => (<li class="border-b border-slate-100 py-1"><span class="font-mono text-xs">{s.name}</span> — {s.usage || s.description}</li>))}
        </ul>
      </section>
    )}
  </div>

  {relGroups.length > 0 && (
    <section class="mt-8">
      <h2 class="mb-2 text-lg font-semibold">Related components</h2>
      <div class="flex flex-col gap-2 text-sm">
        {relGroups.map((g) => (
          <div class="flex flex-wrap items-center gap-2">
            <span class="w-20 shrink-0 text-slate-400">{g.label}</span>
            {g.ids.map((id) => {
              const t = byId.get(id);
              return t ? (
                <a href={rebase(`/c/${id}`, BASE)} class="rounded-full border border-slate-200 px-3 py-1 hover:border-slate-400">
                  {t.display_name} <span class="text-slate-400">· {t.categorization.atomic_type}</span>
                </a>
              ) : (
                <span class="rounded-full border border-dashed border-slate-200 px-3 py-1 text-slate-400">{id}</span>
              );
            })}
          </div>
        ))}
      </div>
    </section>
  )}

  {entry.how_to_use && (
    <section class="mt-8">
      <h2 class="mb-2 text-lg font-semibold">How to use</h2>
      <p class="max-w-2xl whitespace-pre-line text-sm text-slate-600">{entry.how_to_use}</p>
    </section>
  )}

  {entry.use_cases.length > 0 && (
    <section class="mt-8">
      <h2 class="mb-2 text-lg font-semibold">Use cases</h2>
      <ul class="list-disc pl-5 text-sm text-slate-600">{entry.use_cases.map((u) => (<li>{u}</li>))}</ul>
    </section>
  )}

  <section class="mt-8 flex flex-wrap gap-2 text-xs">
    {cat.usage_type?.map((u) => (<span class="rounded bg-slate-100 px-2 py-1 text-slate-600">{u}</span>))}
    {cat.wcag?.level && <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700">WCAG {cat.wcag.level}</span>}
    {typeof cat.seo_score === "number" && <span class="rounded bg-slate-100 px-2 py-1 text-slate-600">SEO {cat.seo_score}</span>}
    {cat.text_direction && <span class="rounded bg-slate-100 px-2 py-1 text-slate-600">dir: {cat.text_direction}</span>}
    <span class="rounded bg-slate-100 px-2 py-1 text-slate-600">{cat.maturity}</span>
  </section>

  <script is:inline define:vars={{ behaviors }}>
    const THEME_KEY = "magoo-theme";
    // Assigned by the width control below; lets theme/container changes rebuild the
    // responsive iframes so they always reflect the current theme + stage content.
    let onStageChange = null;
    function applyTheme(themeId) {
      document.querySelectorAll(".stage").forEach((s) => { s.dataset.theme = themeId; });
      document.querySelectorAll(".theme-btn").forEach((b) => b.setAttribute("aria-current", String(b.dataset.themeId === themeId)));
      if (onStageChange) onStageChange();
    }
    document.querySelectorAll(".theme-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        applyTheme(btn.dataset.themeId);
        try { localStorage.setItem(THEME_KEY, btn.dataset.themeId); } catch {}
      });
    });
    // Restore the last-picked theme (persists across pages).
    try {
      const saved = localStorage.getItem(THEME_KEY);
      if (saved && document.querySelector(`.theme-btn[data-theme-id="${saved}"]`)) applyTheme(saved);
    } catch {}

    // Container preview: swap each stage between the card standalone and pre-rendered
    // variants that place the card inside a real container component (grid, slider, …).
    const layout = document.getElementById("layout");
    if (layout) {
      const stages = [...document.querySelectorAll(".stage-content")].map((el) => {
        let variants = {};
        try { variants = JSON.parse(el.dataset.variants || "{}"); } catch {}
        return { el, variants };
      });
      const LAYOUT_KEY = "magoo-layout";
      function applyLayout(key) {
        for (const { el, variants } of stages) {
          const html = variants[key] || variants.single;
          if (html != null) el.innerHTML = html;
        }
        if (onStageChange) onStageChange();
      }
      layout.addEventListener("change", () => {
        applyLayout(layout.value);
        try { localStorage.setItem(LAYOUT_KEY, layout.value); } catch {}
      });
      try {
        const savedLayout = localStorage.getItem(LAYOUT_KEY);
        if (savedLayout && [...layout.options].some((o) => o.value === savedLayout)) { layout.value = savedLayout; applyLayout(savedLayout); }
      } catch {}
    }

    // Preview width / breakpoint: a single control. "" is auto and "full" breaks the stages
    // out to the viewport — both keep the component in the page DOM. A numeric value renders
    // each stage inside an <iframe> sized to that width: an iframe is its own viewport, so the
    // component's sm:/lg: media queries fire exactly like on a real device of that width
    // (constraining the container alone would leave a desktop viewport, cramming lg: columns).
    const stagesWrap = document.getElementById("stages");
    const widthSel = document.getElementById("stage-width");
    if (widthSel && stagesWrap) {
      const W_KEY = "magoo-stage-width";
      // Same compiled Tailwind + theme CSS the page uses, so frames render identically. Copy BOTH
      // <link rel="stylesheet"> (production build) AND inline <style> tags (dev, where Astro/Vite
      // injects CSS as <style> not links) — otherwise the frame renders unstyled in dev.
      const pageCss = () => [...document.querySelectorAll('link[rel="stylesheet"], style')].map((el) => el.outerHTML).join("");
      const baseHref = document.baseURI;

      function currentTheme() {
        const b = document.querySelector('.theme-btn[aria-current="true"]');
        return (b && b.dataset.themeId) || "simple";
      }
      function clearFrames() {
        stagesWrap.querySelectorAll(".stage-frame").forEach((f) => f.remove());
        stagesWrap.querySelectorAll(".stage-content").forEach((c) => { c.style.display = ""; });
      }
      // An iframe at `width` with its own viewport; the theme lives on <body data-theme>,
      // and the component's behaviors run inside so interactivity works there too.
      function buildFrame(html, width, theme) {
        const iframe = document.createElement("iframe");
        iframe.className = "stage-frame";
        iframe.setAttribute("title", "Responsive preview at " + width + "px");
        iframe.style.cssText = "width:" + width + "px;max-width:100%;border:0;display:block;margin:0 auto;height:240px;";
        const links = pageCss();
        iframe.srcdoc =
          '<!doctype html><html><head><meta charset="utf-8">' +
          '<meta name="viewport" content="width=' + width + '">' +
          '<base href="' + baseHref + '">' + links +
          '<style>html,body{margin:0}body{padding:16px}</style></head>' +
          '<body data-theme="' + theme + '">' + html + '</body></html>';
        iframe.addEventListener("load", () => {
          const d = iframe.contentDocument;
          if (!d) return;
          for (const js of (behaviors || [])) {
            try { const s = d.createElement("script"); s.textContent = js; d.body.appendChild(s); } catch {}
          }
          const fit = () => { try { iframe.style.height = d.documentElement.scrollHeight + "px"; } catch {} };
          fit(); setTimeout(fit, 120); setTimeout(fit, 450);
        });
        return iframe;
      }
      function applyWidth(v) {
        const full = v === "full";
        stagesWrap.classList.toggle("full-bleed", full);
        clearFrames();
        if (!v || full) return;                       // auto / full → in-page stages
        const width = parseInt(v, 10);
        const theme = currentTheme();
        stagesWrap.querySelectorAll(".stage").forEach((s) => {
          const content = s.querySelector(".stage-content");
          if (!content) return;
          content.style.display = "none";             // hide the in-page copy, keep it for restore
          s.appendChild(buildFrame(content.innerHTML, width, theme));
        });
      }
      // Rebuild frames when the theme or container selection changes while a width is active.
      onStageChange = () => { const v = widthSel.value; if (v && v !== "full") applyWidth(v); };
      widthSel.addEventListener("change", () => {
        applyWidth(widthSel.value);
        try { localStorage.setItem(W_KEY, widthSel.value); } catch {}
      });
      try {
        const saved = localStorage.getItem(W_KEY);
        if (saved && [...widthSel.options].some((o) => o.value === saved)) { widthSel.value = saved; applyWidth(saved); }
      } catch {}
    }

    // The viewed component's own behavior, plus any slotted children's, so
    // composed demos (e.g. ticket-card steppers inside ticket-selector) are live.
    for (const js of behaviors || []) {
      const s = document.createElement("script");
      s.textContent = js;
      document.body.appendChild(s);
    }

    // Metadata modal: show the raw metadata.yml on demand.
    const metaModal = document.getElementById("meta-modal");
    const metaBtn = document.getElementById("meta-btn");
    if (metaModal && metaBtn) {
      const openMeta = () => { metaModal.hidden = false; document.body.style.overflow = "hidden"; };
      const closeMeta = () => { metaModal.hidden = true; document.body.style.overflow = ""; };
      metaBtn.addEventListener("click", openMeta);
      document.getElementById("meta-close").addEventListener("click", closeMeta);
      metaModal.addEventListener("click", (e) => { if (e.target === metaModal) closeMeta(); });
      document.addEventListener("keydown", (e) => { if (!metaModal.hidden && e.key === "Escape") closeMeta(); });
    }
  </script>

  <style is:global>
    /* Full-bleed: break the stages out of the centered max-width column to the viewport. */
    #stages.full-bleed {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
  </style>
</Layout>
