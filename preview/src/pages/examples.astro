---
import Layout from "../layouts/Layout.astro";
import { loadCatalog, loadRender, renderSlotted, renderSlots, rebase, rebaseHtml, THEMES } from "../lib/data.js";
import { EXAMPLE_PAGES } from "../lib/examples.js";
import { renderToHtml } from "@magoo/generator";

const BASE = import.meta.env.BASE_URL;
const nameById = new Map(loadCatalog().components.map((c) => [c.id, c.display_name]));
const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
// Link (chain) icon revealed on hover so you can jump to a component's detail page.
const LINK_ICON = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';

// Wrap one rendered component so a "link to this component" affordance can appear on hover.
function wrapItem(id, html) {
  const name = nameById.get(id) || id;
  const href = rebase(`/c/${id}`, BASE);
  return `<div class="ex-item" data-id="${esc(id)}">` +
    `<a class="ex-link" href="${esc(href)}" title="Open the ${esc(name)} component" aria-label="Open the ${esc(name)} component">` +
    `${LINK_ICON}<span>${esc(name)}</span></a>${html}</div>`;
}

// Render each example page once, at build time: stack every component's curated default
// render, and collect the behaviors so interactive pieces (sliders, accordions, menus) work.
// Render one composition item to { html, behaviors }. Item shapes:
//   "id"                         a catalog component
//   { id, wrap }                 a component placed in a CSS container (e.g. a reading column)
//   { id, args }                 a component rendered with its default args merged with overrides
//                                 (e.g. a real video src, custom transcript cues) — top-level props
//   { raw }                      a raw HTML blob (article body, a heading) — no component link
//   { split: { ratio, gap, stack, start, end }, wrap }
//                                 start & end placed in the layout/split-view component at a
//                                 variable width ratio (e.g. "70-30", "80-20"); stacks on mobile.
//                                 Each pane is one item OR an array of items stacked with a gap.
//   { id, slots: { name: item | [items] } }  a slot value may be one item or an array (e.g. many
//                                 cards for a card-grid's items slot)
//   { section: [items], title }  the items wrapped in layout/section-wrapper for padding
//                                 (omit title → pure padding; set title → a section heading)
function renderItem(item) {
  if (item && typeof item === "object" && item.raw) {
    return { html: `<div class="ex-item">${rebaseHtml(item.raw, BASE)}</div>`, behaviors: [] };
  }
  if (item && typeof item === "object" && item.split) {
    const { start, end, ...opts } = item.split; // opts: ratio, gap, stack, …
    // A pane may be a single item or an array of items stacked (flex column) with a gap.
    const pane = (p) => {
      if (!Array.isArray(p)) return renderItem(p);
      const parts = p.map(renderItem);
      return { html: `<div class="flex flex-col gap-6">${parts.map((r) => r.html).join("\n")}</div>`, behaviors: parts.flatMap((r) => r.behaviors) };
    };
    const s = pane(start);
    const e = pane(end);
    const behaviors = [...s.behaviors, ...e.behaviors];
    const sv = renderSlots("layout/split-view", { start: s.html, end: e.html }, opts);
    let html = sv ? sv.html : `${s.html}\n${e.html}`;
    if (sv && sv.behavior) behaviors.push(sv.behavior);
    if (item.wrap) html = `<div class="${item.wrap}">${html}</div>`;
    return { html, behaviors };
  }
  if (item && typeof item === "object" && Array.isArray(item.row)) {
    const inner = item.row.map(renderItem);
    const cls = item.wrap || "flex flex-wrap items-center gap-3";
    return { html: `<div class="${cls}">${inner.map((r) => r.html).join("\n")}</div>`, behaviors: inner.flatMap((r) => r.behaviors) };
  }
  if (item && typeof item === "object" && Array.isArray(item.section)) {
    const inner = item.section.map(renderItem);
    const behaviors = inner.flatMap((r) => r.behaviors);
    const innerHtml = inner.map((r) => r.html).join("\n");
    // section-wrapper adds vertical padding; empty eyebrow/title/description → padding only.
    // `padding` ("default" | "compact" | "none") tunes how much.
    const extra = { eyebrow: "", title: item.title || "", description: "" };
    if (item.padding) extra.padding = item.padding;
    const sw = renderSlotted("layout/section-wrapper", "content", innerHtml, extra);
    if (!sw) return { html: innerHtml, behaviors };
    if (sw.behavior) behaviors.push(sw.behavior);
    return { html: sw.html, behaviors }; // inner html is already rebased
  }
  const id = typeof item === "string" ? item : item.id;
  try {
    const { ast, args, behaviors } = loadRender(id);
    let merged = item && item.args ? { ...args, ...item.args } : args;
    // { slots: { name: item } } renders each child item and slots its HTML into this component
    // (e.g. a watch-next-rail into video-player's end_screen, or rich-text into spacing-box).
    const slotBehaviors = [];
    if (item && item.slots) {
      const slots = { ...(merged.$slots || {}) };
      for (const [name, child] of Object.entries(item.slots)) {
        // A slot value may be one item or an array (e.g. several cards for a card-grid's items).
        const kids = (Array.isArray(child) ? child : [child]).map(renderItem);
        slots[name] = kids.map((r) => r.html).join("\n");
        slotBehaviors.push(...kids.flatMap((r) => r.behaviors));
      }
      merged = { ...merged, $slots: slots };
    }
    let html = rebaseHtml(renderToHtml(ast, merged), BASE);
    if (item && item.wrap) html = `<div class="${item.wrap}">${html}</div>`;
    return { html: wrapItem(id, html), behaviors: [...behaviors, ...slotBehaviors] };
  } catch {
    return { html: "", behaviors: [] };
  }
}

const pages = EXAMPLE_PAGES.map((pg) => {
  const behaviors = [];
  const parts = [];
  for (const item of pg.components) {
    const r = renderItem(item);
    if (r.html) parts.push(r.html);
    for (const b of r.behaviors) if (!behaviors.includes(b)) behaviors.push(b);
  }
  return { ...pg, html: parts.join("\n"), behaviors };
});
const pagesData = Object.fromEntries(pages.map((p) => [p.id, p.html]));
const descData = Object.fromEntries(pages.map((p) => [p.id, p.description]));
const behaviors = [...new Set(pages.flatMap((p) => p.behaviors))];
const first = pages[0];
---

<Layout title="Examples — Magoo Component UI">
  <h1 class="text-2xl font-semibold tracking-tight">Examples</h1>
  <p class="mt-2 max-w-2xl text-slate-600">
    Full pages assembled from catalog components — see how the CSS-less skeletons combine, and
    how one composition looks across all four themes and at each breakpoint.
  </p>

  <!-- Toolbar: example · styling (theme) · breakpoint (incl. full width) -->
  <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
    <label class="flex items-center gap-2 text-sm text-slate-600">
      Example
      <select id="ex-select" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm outline-none focus:border-slate-500">
        {pages.map((p) => (<option value={p.id}>{p.label}</option>))}
      </select>
    </label>
    <label class="flex items-center gap-2 text-sm text-slate-600">
      Styling
      <select id="ex-theme" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm outline-none focus:border-slate-500">
        {THEMES.map((t) => (<option value={t.id}>{t.label}</option>))}
      </select>
    </label>
    <label class="flex items-center gap-2 text-sm text-slate-600">
      Breakpoint
      <select id="ex-width" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm outline-none focus:border-slate-500">
        <option value="full">Full width</option>
        <option value="">Auto width</option>
        <option value="1440">Desktop · 1440</option>
        <option value="1024">Small · 1024</option>
        <option value="768">Tablet · 768</option>
        <option value="375">Mobile · 375</option>
      </select>
    </label>
  </div>
  <!-- The breakpoint preview renders in a fixed-width frame, so it only helps on a screen wider
       than the chosen width — on a phone the frame is capped to the viewport. -->
  <p class="mt-2 text-xs text-slate-400">
    The breakpoint preview needs a screen wider than the chosen width — use a larger device (or a
    desktop browser) to see the desktop and tablet layouts.
  </p>
  <p id="ex-desc" class="mt-2 text-sm text-slate-500">{first?.description}</p>

  <div id="ex-wrap" class="mt-4">
    <div id="ex-stage" data-theme="simple" class="overflow-hidden rounded-xl border border-slate-200">
      <div id="ex-content" class="ex-contained" set:html={first?.html} />
    </div>
  </div>

  <script is:inline define:vars={{ pagesData, descData, behaviors }}>
    const sel = document.getElementById("ex-select");
    const themeSel = document.getElementById("ex-theme");
    const widthSel = document.getElementById("ex-width");
    const stage = document.getElementById("ex-stage");
    const wrap = document.getElementById("ex-wrap");
    const content = document.getElementById("ex-content");
    const desc = document.getElementById("ex-desc");

    // The same compiled Tailwind + theme CSS this page uses, so an iframe renders identically.
    // We copy BOTH <link rel="stylesheet"> (production build) AND inline <style> tags (dev, where
    // Astro/Vite injects CSS as <style> rather than links) — otherwise the frame renders unstyled.
    // baseHref lets the frame resolve the same asset URLs (logo, stock images).
    const pageCss = () => [...document.querySelectorAll('link[rel="stylesheet"], style')].map((el) => el.outerHTML).join("");
    const baseHref = document.baseURI;
    let frame = null; // the active responsive iframe, or null when rendering in-page

    function applyExample(id) {
      if (pagesData[id] == null) return;
      content.innerHTML = pagesData[id];
      desc.textContent = descData[id] || "";
      if (frame) applyWidth(widthSel.value); // rebuild the frame with the new example
    }
    // Reflect the chosen example in the URL (?example=<id>) so a specific one can be hotlinked.
    function syncUrl(id) {
      const p = new URLSearchParams(location.search);
      p.set("example", id);
      history.replaceState(null, "", location.pathname + "?" + p.toString() + location.hash);
    }
    function applyTheme(id) {
      stage.dataset.theme = id;
      if (frame) applyWidth(widthSel.value); // rebuild so the frame body picks up the new theme
    }
    function clearFrame() {
      if (frame) { frame.remove(); frame = null; }
      content.style.display = "";
    }
    // A real breakpoint preview: render the example inside an <iframe> sized to `width`. An
    // iframe is its own viewport, so the components' sm:/lg: media queries fire exactly like a
    // device of that width — which a mere max-width on a div can't do. Behaviors run inside too.
    function buildFrame(html, width, theme) {
      // Wide previews sit in a ~1200px centered page column (like the real page); the narrow
      // tablet/mobile widths drop the cap so the viewport width itself is the constraint.
      const narrow = width <= 768;
      const shell = narrow
        ? html
        : '<div style="max-width:1200px;margin-inline:auto">' + html + "</div>";
      const f = document.createElement("iframe");
      f.className = "ex-frame";
      f.setAttribute("title", "Responsive preview at " + width + "px");
      // The frame's height is fitted to its content below, so it never needs to scroll — disable
      // its scrollbars so no dead scrollbar gutter shows on the narrow (small/tablet/mobile) widths.
      f.setAttribute("scrolling", "no");
      f.style.cssText = "width:" + width + "px;max-width:100%;border:0;display:block;margin:0 auto;height:600px";
      f.srcdoc =
        '<!doctype html><html><head><meta charset="utf-8">' +
        '<meta name="viewport" content="width=' + width + '">' +
        '<base href="' + baseHref + '">' + pageCss() +
        // The per-component hover-link pills are a page affordance (their CSS is page-scoped and
        // they can't navigate the parent from here) — hide them inside the responsive frame.
        // Kill the frame's own scrollbars: its height is fitted to content (below), so it never
        // needs to scroll — this removes the dead vertical scrollbar on small/tablet/mobile.
        '<style>html{overflow:hidden}html,body{margin:0}body{padding:16px 16px 24px}.ex-link{display:none!important}</style></head>' +
        '<body data-theme="' + theme + '">' + shell + "</body></html>";
      f.addEventListener("load", () => {
        const d = f.contentDocument;
        if (!d) return;
        for (const js of (behaviors || [])) {
          try { const s = d.createElement("script"); s.textContent = js; d.body.appendChild(s); } catch {}
        }
        // Fit the frame to its content. With overflow hidden, an out-of-date height would clip, so
        // keep it accurate as late content (images, the end-screen) reflows via a ResizeObserver.
        const fit = () => { try { f.style.height = d.documentElement.scrollHeight + "px"; } catch {} };
        fit(); setTimeout(fit, 120); setTimeout(fit, 450);
        try { new (f.contentWindow.ResizeObserver)(fit).observe(d.documentElement); } catch {}
      });
      return f;
    }
    function applyWidth(v) {
      // Any explicit width (full or a breakpoint) breaks out of the page column so the stage
      // can actually reach that width; "auto" stays inside the normal column.
      wrap.classList.toggle("full-bleed", v !== "");
      clearFrame();
      if (!v || v === "full") {
        // Auto / full width render in-page; content sits in a ~1200px centered container.
        stage.style.maxWidth = "";
        stage.style.marginInline = "";
        content.classList.add("ex-contained");
        return;
      }
      // A numeric breakpoint: swap the in-page copy for an iframe at that exact width.
      stage.style.maxWidth = "";
      stage.style.marginInline = "";
      content.style.display = "none";
      frame = buildFrame(content.innerHTML, parseInt(v, 10), stage.dataset.theme || "simple");
      stage.appendChild(frame);
    }

    sel.addEventListener("change", () => { applyExample(sel.value); syncUrl(sel.value); });
    themeSel.addEventListener("change", () => {
      applyTheme(themeSel.value);
      try { localStorage.setItem("magoo-theme", themeSel.value); } catch {}
    });
    widthSel.addEventListener("change", () => {
      applyWidth(widthSel.value);
      try { localStorage.setItem("magoo-example-width", widthSel.value); } catch {}
    });

    // Deep-link: ?example=<id> selects (and renders) that example on load; otherwise keep the
    // server-rendered first example. Always normalize the URL so it carries the current example.
    const urlExample = new URLSearchParams(location.search).get("example");
    if (urlExample && [...sel.options].some((o) => o.value === urlExample)) {
      sel.value = urlExample;
      applyExample(urlExample);
    }
    syncUrl(sel.value);

    // Restore the shared theme pick + last example width.
    try {
      const t = localStorage.getItem("magoo-theme");
      if (t && [...themeSel.options].some((o) => o.value === t)) themeSel.value = t;
      const w = localStorage.getItem("magoo-example-width");
      if (w != null && [...widthSel.options].some((o) => o.value === w)) widthSel.value = w;
    } catch {}
    applyTheme(themeSel.value);
    applyWidth(widthSel.value);

    // Load every example's behaviors once; the portable self-init wrappers pick up the
    // swapped-in markup via their MutationObserver when the example changes.
    for (const js of behaviors || []) {
      const s = document.createElement("script");
      s.textContent = js;
      document.body.appendChild(s);
    }
  </script>

  <style is:global>
    /* Full-bleed: break the example stage out of the centered max-width column. */
    #ex-wrap.full-bleed {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    /* Content container: always a small gutter; capped to ~1200px & centered except on
       tablet/mobile widths (where the narrow viewport is the point). */
    #ex-content { padding-inline: 1rem; padding-block: 1.5rem; }
    #ex-content.ex-contained { max-width: 1200px; margin-inline: auto; }

    /* Per-component "open this component" affordance, revealed on hover (desktop only). */
    .ex-item { position: relative; }
    .ex-link {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      z-index: 50;
      display: none;
      align-items: center;
      gap: 0.375rem;
      padding: 0.3rem 0.6rem;
      border-radius: 9999px;
      background: rgba(255, 255, 255, 0.96);
      color: #0f172a;
      border: 1px solid rgba(15, 23, 42, 0.15);
      box-shadow: 0 2px 10px rgba(15, 23, 42, 0.18);
      font: 500 12px/1 ui-sans-serif, system-ui, sans-serif;
      text-decoration: none;
      white-space: nowrap;
    }
    .ex-link:hover { border-color: rgba(15, 23, 42, 0.4); background: #fff; }
    /* Only reveal where hovering is meaningful (fine pointer) and there's room (desktop). */
    @media (hover: hover) and (pointer: fine) and (min-width: 768px) {
      .ex-item:hover > .ex-link { display: inline-flex; }
    }
  </style>
</Layout>
