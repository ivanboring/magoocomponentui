---
import Layout from "../layouts/Layout.astro";
import { loadCatalog, loadRender, orderedShots, rebase, rebaseHtml } from "../lib/data.js";
import { renderToHtml } from "@magoo/generator";

const BASE = import.meta.env.BASE_URL;
const catalog = loadCatalog();
const cards = [...catalog.components]
  .sort((a, b) => a.display_name.localeCompare(b.display_name))
  .map((c) => {
  let preview = "";
  try {
    const { ast, args } = loadRender(c.id);
    preview = rebaseHtml(renderToHtml(ast, args), BASE);
  } catch {}
  const hasShots = Object.keys(c.screenshots || {}).length > 0;
  // Rebase the per-card screenshot map so <img> srcs resolve under the deploy base.
  const screenshots = BASE === "/" ? c.screenshots : JSON.parse(rebaseHtml(JSON.stringify(c.screenshots || {}), BASE));
  return { ...c, preview, hasShots, screenshots };
});
const categories = catalog.facets.categories || {};
---

<Layout title="Magoo Component UI — Catalog">
  <!-- Top toolbar: search + category dropdown -->
  <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center">
    <input
      id="search"
      type="search"
      placeholder="Search components…"
      class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm outline-none focus:border-slate-500 sm:max-w-xs"
    />
    <select
      id="cat"
      class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm outline-none focus:border-slate-500 sm:w-auto"
    >
      <option value="">All categories</option>
      {Object.entries(categories).map(([cat, subs]) => (
        <optgroup label={cat}>
          <option value={cat}>{cat} — all</option>
          {subs.map((sub) => (<option value={`${cat}::${sub}`}>{cat} › {sub}</option>))}
        </optgroup>
      ))}
    </select>
    <label class="flex shrink-0 items-center gap-2 text-sm text-slate-600 sm:ml-auto">
      <input id="hide-atoms" type="checkbox" checked class="size-4 rounded border-slate-300" />
      Hide atoms
    </label>
  </div>

  {cards.length === 0 && (
    <p class="rounded-lg border border-dashed border-slate-300 p-8 text-center text-slate-500">
      No components yet. Author one under <code>components/</code> and run <code>pnpm build</code>.
    </p>
  )}

  <p id="count" class="mb-3 text-sm text-slate-400"></p>

  <div id="grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {cards.map((c) => (
      <a
        href={rebase(`/c/${c.id}`, BASE)}
        class="card group block overflow-hidden rounded-xl border border-slate-200 bg-white transition hover:border-slate-300 hover:shadow-sm"
        data-cat={c.categorization.category}
        data-cats={[c.categorization.category, ...(c.secondary_categories || [])].join("|")}
        data-sub={c.categorization.subcategory || ""}
        data-atomic={c.categorization.atomic_type}
        data-search={`${c.name} ${c.display_name} ${c.short_description} ${(c.use_cases || []).join(" ")}`.toLowerCase()}
      >
        <div class="flex items-center justify-center border-b border-slate-100 bg-slate-50 p-5" data-theme="simple">
          {c.hasShots ? (
            <img
              class="card-shot w-full rounded"
              src={(c.screenshots.simple && c.screenshots.simple.desktop) || ""}
              alt={`${c.display_name} preview`}
              loading="lazy"
            />
          ) : (
            <div class="pointer-events-none w-full" set:html={c.preview} />
          )}
        </div>
        <div class="p-4">
          <div class="flex items-center gap-2">
            <h3 class="font-semibold">{c.display_name}</h3>
            <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] text-slate-500">{c.categorization.atomic_type}</span>
          </div>
          <code class="mt-0.5 block font-mono text-[11px] text-slate-400">{c.name}</code>
          <p class="mt-1 line-clamp-2 text-sm text-slate-500">{c.short_description}</p>
        </div>
      </a>
    ))}
  </div>
  <p id="empty" class="hidden py-12 text-center text-slate-400">No components match.</p>
  <nav id="pager" class="mt-8 flex items-center justify-center gap-1 text-sm"></nav>

  <script>
    const PAGE_SIZE = 20;
    const search = document.getElementById("search");
    const catSelect = document.getElementById("cat");
    const hideAtoms = document.getElementById("hide-atoms");
    const cards = Array.from(document.querySelectorAll(".card"));
    let page = 1;

    // ---- URL state: search / category / hide-atoms / page round-trip to the query string
    //      so a filtered view survives reload and can be shared. ----
    function syncFromUrl() {
      const p = new URLSearchParams(location.search);
      search.value = p.get("q") || "";
      const cat = p.get("cat") || "";
      catSelect.value = [...catSelect.options].some((o) => o.value === cat) ? cat : "";
      hideAtoms.checked = p.get("atoms") !== "1"; // atoms=1 means "show atoms" (checkbox off)
      const n = parseInt(p.get("page") || "1", 10);
      page = Number.isFinite(n) && n > 0 ? n : 1;
    }

    function updateUrl(push = false) {
      const p = new URLSearchParams();
      if (search.value.trim()) p.set("q", search.value.trim());
      if (catSelect.value) p.set("cat", catSelect.value);
      if (!hideAtoms.checked) p.set("atoms", "1");
      if (page > 1) p.set("page", String(page));
      const qs = p.toString();
      const url = location.pathname + (qs ? "?" + qs : "");
      if (push) history.pushState(null, "", url);
      else history.replaceState(null, "", url);
    }

    const empty = document.getElementById("empty");
    const count = document.getElementById("count");
    const pager = document.getElementById("pager");

    function matches(card) {
      const q = (search.value || "").trim().toLowerCase();
      const [cat, sub] = (catSelect.value || "").split("::");
      const cats = (card.dataset.cats || card.dataset.cat || "").split("|");
      let catOk;
      if (!cat) catOk = true;
      else if (sub) catOk = card.dataset.cat === cat && card.dataset.sub === sub; // specific sub → primary home only
      else catOk = cats.includes(cat);                                            // "— all" → any membership
      return (!q || card.dataset.search.includes(q)) && catOk &&
        (!hideAtoms.checked || card.dataset.atomic !== "atom");
    }

    function render() {
      const matched = cards.filter(matches);
      const pages = Math.max(1, Math.ceil(matched.length / PAGE_SIZE));
      if (page > pages) page = pages;
      const start = (page - 1) * PAGE_SIZE;
      const visible = new Set(matched.slice(start, start + PAGE_SIZE));
      for (const card of cards) card.classList.toggle("hidden", !visible.has(card));
      empty.classList.toggle("hidden", matched.length !== 0);
      count.textContent = matched.length ? `Showing ${visible.size} of ${matched.length}` : "";
      renderPager(pages);
    }

    function pageButton(label, target, opts = {}) {
      const b = document.createElement("button");
      b.textContent = label;
      b.className = "rounded-md border px-3 py-1 " +
        (opts.current ? "border-slate-900 bg-slate-900 text-white" : "border-slate-300 hover:bg-slate-100") +
        (opts.disabled ? " cursor-not-allowed opacity-40" : "");
      if (opts.disabled) b.disabled = true;
      else b.addEventListener("click", () => { page = target; updateUrl(true); render(); window.scrollTo({ top: 0 }); });
      return b;
    }

    function renderPager(pages) {
      pager.innerHTML = "";
      if (pages <= 1) return;
      pager.appendChild(pageButton("‹ Prev", page - 1, { disabled: page === 1 }));
      // windowed page numbers
      const win = [];
      for (let p = 1; p <= pages; p++) {
        if (p === 1 || p === pages || Math.abs(p - page) <= 2) win.push(p);
        else if (win[win.length - 1] !== "…") win.push("…");
      }
      for (const p of win) {
        if (p === "…") {
          const s = document.createElement("span");
          s.textContent = "…";
          s.className = "px-2 text-slate-400";
          pager.appendChild(s);
        } else {
          pager.appendChild(pageButton(String(p), p, { current: p === page }));
        }
      }
      pager.appendChild(pageButton("Next ›", page + 1, { disabled: page === pages }));
    }

    search.addEventListener("input", () => { page = 1; updateUrl(); render(); });
    catSelect.addEventListener("change", () => { page = 1; updateUrl(); render(); });
    hideAtoms.addEventListener("change", () => { page = 1; updateUrl(); render(); });
    // Back/forward re-reads the URL so filter + page state stays in sync.
    window.addEventListener("popstate", () => { syncFromUrl(); render(); });

    syncFromUrl();
    render();
  </script>
</Layout>
